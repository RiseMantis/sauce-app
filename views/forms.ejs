<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="style.css">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Message</title>
</head>
<body>
  <h2> Now's your time to be a big shot </h2>
  <br />
  <form method="post" action="/new">
    <label for="name">From: </label>
    <input type="text" id="name" name="name" placeholder="Sender's Name" required>

    <br/>
    <br/>

    <label for="message">Text:  </label>
    <input type="text" id="message" name="text" placeholder="Your Message" required>

    <br/>
    <br/>

    <button type="submit" class="send-button" style="cursor: pointer;">
      Submit
    </button>
  </form>
</body>
</html>